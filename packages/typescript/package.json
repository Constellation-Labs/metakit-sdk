{
  "name": "@constellation-network/metagraph-sdk",
  "version": "1.8.0-rc.7",
  "description": "TypeScript SDK for signing data and currency transactions on Constellation data metagraphs built with metakit. Re-exports the signing kernel and adds the currency-transaction layer and network client.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    },
    "./network": {
      "import": "./dist/esm/network/index.js",
      "require": "./dist/cjs/network/index.js",
      "types": "./dist/types/network/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:bundle && npm run build:types",
    "build:bundle": "rollup -c",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "constellation",
    "metagraph",
    "dag",
    "ecdsa",
    "secp256k1",
    "signature",
    "blockchain",
    "rfc8785",
    "canonicalize"
  ],
  "author": "Constellation Network",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Constellation-Labs/metakit-sdk.git",
    "directory": "packages/typescript"
  },
  "bugs": {
    "url": "https://github.com/Constellation-Labs/metakit-sdk/issues"
  },
  "homepage": "https://github.com/Constellation-Labs/metakit-sdk/tree/main/packages/typescript#readme",
  "dependencies": {
    "@constellation-network/metagraph-sdk-core": "1.8.0-rc.7",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "@constellation-network/metagraph-sdk-jlvm": "1.8.0-rc.7",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "jest": "^30.2.0",
    "eslint": "^10.0.2",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@types/node": "^25.3.3",
    "@types/jest": "^30.0.0",
    "prettier": "^3.0.0",
    "rollup": "^4.59.0",
    "ts-jest": "^29.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
