{
  "name": "@constellation-network/metagraph-sdk-jlvm",
  "version": "1.8.0-rc.5",
  "description": "JSON Logic Virtual Machine (JLVM) for Constellation metagraphs: the evaluator, gas metering, and zk/crypto opcodes. Self-contained.",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "npm run build:bundle && npm run build:types",
    "build:bundle": "rollup -c",
    "build:types": "tsc -p tsconfig.types.json",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src tests",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "constellation",
    "metagraph",
    "json-logic",
    "jlvm",
    "virtual-machine",
    "evaluator",
    "gas",
    "zk",
    "poseidon"
  ],
  "author": "Constellation Network",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Constellation-Labs/metakit-sdk.git",
    "directory": "packages/typescript-jlvm"
  },
  "bugs": {
    "url": "https://github.com/Constellation-Labs/metakit-sdk/issues"
  },
  "homepage": "https://github.com/Constellation-Labs/metakit-sdk/tree/main/packages/typescript-jlvm#readme",
  "dependencies": {
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-typescript": "^12.3.0",
    "jest": "^30.2.0",
    "eslint": "^10.0.2",
    "@typescript-eslint/parser": "^8.56.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@types/node": "^25.3.3",
    "@types/jest": "^30.0.0",
    "prettier": "^3.0.0",
    "rollup": "^4.59.0",
    "ts-jest": "^29.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
