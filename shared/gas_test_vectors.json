{
  "description" : "JLVM gas-metering cross-language test vectors. Scala (metakit) is the reference gas meter; every implementation must reproduce `expected` EXACTLY: the integer gasUsed reported when evaluating `expr` against `data` under `gasLimit` with the default gas schedule, or the string \"OOG\" when metering must fail with the distinct gas-exhaustion error. The charging contract is normative per metakit PR #37: each op consumes exactly once base(op) + depthPenalty + inputScaledCost atomically BEFORE the primitive runs, plus an output-scaled residual after it for split/merge/flatten/slice/substr only; var lookups consume varAccess + #pathSegments at lookup; the lazily-dispatched if/let charge their flat base cost once per node at the dispatch site with NO depth penalty (untaken branches cost nothing); gasUsed is the gas-counter delta. Generated by `sbt \"Test/runMain json_logic.GasVectorGenerator\"` — expected values are PRODUCED BY RUNNING the Scala meter, never hand-computed.",
  "version" : "1.1.0",
  "tests" : [
    {
      "category" : "constants",
      "note" : "Literals are never charged: constants, array literals and object literals cost 0 gas.",
      "cases" : [
        {
          "expr" : "42",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 0
        },
        {
          "expr" : "[1, 2, 3]",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 0,
          "note" : "array literal: elements are constants, no op charge"
        },
        {
          "expr" : "{\"a\": 1, \"b\": 2}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 0,
          "note" : "object literal: no op charge"
        }
      ]
    },
    {
      "category" : "simple_ops",
      "note" : "Single operation over constant args: base(op) + depthPenalty(1) [+ input-scaled term].",
      "cases" : [
        {
          "expr" : "{\"!\": [true]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 6
        },
        {
          "expr" : "{\"==\": [1, 1]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 8
        },
        {
          "expr" : "{\"max\": [1, 2, 3]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 13,
          "note" : "max over a 3-arg list adds sizeCost(3) on top of base + depth"
        },
        {
          "expr" : "{\"typeof\": [42]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 6
        }
      ]
    },
    {
      "category" : "control_flow",
      "note" : "if/let are evaluated lazily but still charge their flat base cost (ifElse = 10) once per node at the dispatch site, with NO depth penalty (depth is undefined at the lazy dispatch site; see the GasConfig schedule comment). Condition / bindings / taken branch pay for themselves; untaken branches pay nothing.",
      "cases" : [
        {
          "expr" : "{\"if\": [true, 1, 2]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 10,
          "note" : "constant condition + constant branch: only the if base cost"
        },
        {
          "expr" : "{\"if\": [{\">\": [5, 3]}, {\"+\": [1, 2]}, 99]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 29,
          "note" : "condition + taken then-branch are charged; untaken else-branch is not"
        },
        {
          "expr" : "{\"let\": [{\"a\": 1}, {\"var\": \"a\"}]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 13,
          "note" : "constant binding: let base cost + the var lookup"
        },
        {
          "expr" : "{\"let\": [{\"a\": {\"+\": [1, 2]}}, {\"+\": [{\"var\": \"a\"}, 1]}]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 35,
          "note" : "let base cost + binding expression + result expression"
        }
      ]
    },
    {
      "category" : "arithmetic_depth",
      "note" : "Nested arithmetic: each op charges once with depthPenalty(5 * height-of-op-over-its-args); no subtree re-charge.",
      "cases" : [
        {
          "expr" : "{\"+\": [1, 2]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 11
        },
        {
          "expr" : "{\"+\": [1, {\"+\": [2, 3]}]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 27
        },
        {
          "expr" : "{\"+\": [{\"+\": [1, {\"+\": [2, 3]}]}, 4]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 48,
          "note" : "3-deep chain: depth penalties 5/10/15"
        },
        {
          "expr" : "{\"*\": [{\"+\": [1, 2]}, {\"-\": [5, 3]}]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 41,
          "note" : "two depth-1 children under a depth-2 parent"
        },
        {
          "expr" : "{\"pow\": [2, 10]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 35,
          "note" : "pow adds |exponent| as an input-scaled term"
        }
      ]
    },
    {
      "category" : "var_paths",
      "note" : "Variable lookups charge varAccess(2) + #pathSegments once at lookup time (Java String.split('.') segment count).",
      "cases" : [
        {
          "expr" : "{\"var\": \"x\"}",
          "data" : "{\"x\": 42}",
          "gasLimit" : 1000,
          "expected" : 3
        },
        {
          "expr" : "{\"var\": \"a.b.c\"}",
          "data" : "{\"a\": {\"b\": {\"c\": 123}}}",
          "gasLimit" : 1000,
          "expected" : 5,
          "note" : "3 path segments"
        },
        {
          "expr" : "{\"var\": \"\"}",
          "data" : "{\"x\": 1}",
          "gasLimit" : 1000,
          "expected" : 3,
          "note" : "whole-data access: empty key still counts 1 segment"
        },
        {
          "expr" : "{\"var\": [\"missing\", \"fallback\"]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 3,
          "note" : "lookup is charged even when the default is substituted"
        }
      ]
    },
    {
      "category" : "collections",
      "note" : "Collection ops add sizeCost(#elements) up front; per-element callback runs charge their own ops against the same counter.",
      "cases" : [
        {
          "expr" : "{\"map\": [[1, 2, 3], {\"+\": [{\"var\": \"\"}, 1]}]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 60
        },
        {
          "expr" : "{\"filter\": [[1, 2, 3, 4], {\">\": [{\"var\": \"\"}, 2]}]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 63
        },
        {
          "expr" : "{\"reduce\": [[1, 2, 3], {\"+\": [{\"var\": \"current\"}, {\"var\": \"accumulator\"}]}, 0]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 74
        },
        {
          "expr" : "{\"all\": [[1, 2, 3], {\">\": [{\"var\": \"\"}, 0]}]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 51,
          "note" : "all evaluates the predicate for EVERY element (no short-circuit), charging each run"
        },
        {
          "expr" : "{\"merge\": [[1, 2], [3, 4]]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 14,
          "note" : "merge charges an output-scaled residual: sizeCost(#merged elements) after the primitive"
        }
      ]
    },
    {
      "category" : "strings",
      "note" : "cat/join pre-charge the coerced output length from the inputs; split/substr post-charge an output residual.",
      "cases" : [
        {
          "expr" : "{\"cat\": [\"foo\", \"bar\"]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 16,
          "note" : "input-scaled: sum of coerced arg lengths"
        },
        {
          "expr" : "{\"join\": [[\"a\", \"b\", \"c\"], \"-\"]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 20,
          "note" : "input-scaled: element lengths + separator * (n-1)"
        },
        {
          "expr" : "{\"split\": [\"a,b,c\", \",\"]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 26,
          "note" : "output residual: 2 * #pieces, charged after the primitive"
        },
        {
          "expr" : "{\"substr\": [\"hello world\", 0, 5]}",
          "data" : "{}",
          "gasLimit" : 1000,
          "expected" : 18,
          "note" : "output residual: produced string length"
        }
      ]
    },
    {
      "category" : "crypto",
      "note" : "ZK / crypto opcodes (fixtures lifted from the shared ZK opcode vectors; all verify successfully). Per-element components (poseidon per-input, pmt per-sibling, bls-aggregate per-key) are pre-charged from the args.",
